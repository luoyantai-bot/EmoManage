# ===========================================
# 情绪管理与智能坐垫干预系统 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入实际值

# PostgreSQL 数据库连接配置
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/emotion_cushion

# Redis 连接配置
# 格式: redis://主机:端口/数据库编号
REDIS_URL=redis://localhost:6379/0

# 点点甜睡云服务配置
# 厂家提供的登录账号
CUSHION_CLOUD_USERNAME=your_username
CUSHION_CLOUD_PASSWORD=your_password
# Webhook 回调签名验证密钥
CUSHION_CLOUD_WEBHOOK_SECRET=your_webhook_secret

# AI 大模型配置 (硅基流动 SiliconFlow)
SILICONFLOW_API_KEY=your_api_key
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# 应用配置
APP_NAME=情绪管理与智能坐垫干预系统
APP_VERSION=1.0.0
DEBUG=true

# JWT 配置 (可选，用于用户认证)
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
